# Dev image — expects JAR pre-built on the host (mvn package)
# Build on host first: cd backend && mvn package -DskipTests
# Context: ./backend/discovery-service
FROM eclipse-temurin:25-jre-alpine
WORKDIR /app
COPY target/discovery-service-*.jar app.jar
EXPOSE 8761
ENTRYPOINT ["java", "-jar", "app.jar"]
