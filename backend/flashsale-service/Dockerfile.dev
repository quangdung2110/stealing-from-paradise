# Dev image — expects JAR pre-built on the host (mvn package)
# Build on host first: cd backend && mvn package -DskipTests
# Context: ./backend/flashsale-service
FROM eclipse-temurin:25-jre-alpine
WORKDIR /app
COPY target/flashsale-service-*.jar app.jar
EXPOSE 8086
ENTRYPOINT ["java", "-jar", "app.jar"]
